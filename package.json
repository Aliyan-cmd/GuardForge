{
  "name": "guardforge-root",
  "private": true,
  "scripts": {
    "install-all": "npm install --prefix frontend && ./backend/venv/bin/pip install -r backend/requirements.txt",
    "dev-frontend": "npm run dev --prefix frontend",
    "dev-backend": "export PYTHONPATH=$PYTHONPATH:$(pwd)/backend && ./backend/venv/bin/python -m uvicorn app.main:app --reload",
    "dev": "npx concurrently \"npm run dev-frontend\" \"npm run dev-backend\"",
    "docker-up": "docker compose up --build",
    "docker-down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
